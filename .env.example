# ── Minimal SWE Agent 环境变量模板 ──────────────────────────────
# 复制本文件为 .env 并填入你的 key
#
# 说明:
#   - OpenAI 兼容协议可覆盖 OpenAI / DeepSeek / Qwen / Groq / 智谱 / 月之暗面 等
#   - 只要改 LLM_PROVIDER + base_url + model + API key 即可切换

# ── 默认使用哪个 provider ──────────────────────────────────────
# 取值: openai | anthropic
LLM_PROVIDER=openai

# ── OpenAI 兼容 ────────────────────────────────────────────────
# 可换成任意兼容 OpenAI 的 API (DeepSeek, Qwen, 智谱, 月之暗面, Groq ...)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic Claude ───────────────────────────────────────────
# 需要安装: pip install "swe-agent[anthropic]"
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ── Agent 行为参数 ─────────────────────────────────────────────
# 最大 ReAct 步数 (防无限循环)
MAX_STEPS=30
